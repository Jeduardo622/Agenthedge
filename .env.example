# ==== Core API Keys ====
OPENAI_API_KEY="replace-with-openai-key"

# ==== Market & Fundamentals Data ====
ALPHA_VANTAGE_API_KEY="replace-with-alpha-vantage-key"
FMP_API_KEY="replace-with-fmp-key"
FINNHUB_API_KEY="replace-with-finnhub-key"
NEWSAPI_KEY="replace-with-newsapi-key"
YAHOO_COOKIE="optional-if-needed"

# ==== Sentiment & Social ====
REDDIT_CLIENT_ID="pending-reddit-client-id"
REDDIT_CLIENT_SECRET="pending-reddit-client-secret"
REDDIT_USER_AGENT="agenthedge-bot/0.1"
TWITTER_BEARER_TOKEN="optional-if-available"

# ==== Macro & Alt Data ====
FRED_API_KEY="replace-with-fred-key"
WORLD_BANK_API_KEY=""
ALPHA_VANTAGE_TIMESERIES_ENABLED="true"
PROVIDER_HTTP_TIMEOUT_SECONDS="10"
PROVIDER_HEALTH_TTL_SECONDS="300"
PROVIDER_HEALTH_PROBE_SYMBOL="SPY"
PROVIDER_HEALTH_PROBE_SERIES_ID="DGS10"
PROVIDER_HEALTH_PROBE_QUERY="markets"

# ==== Trading Simulator / Broker (Alpaca) ====
EXECUTION_MODE="simulated"
EXECUTION_LIVE_BROKER_ENABLED="false"
EXECUTION_ORDER_LEDGER_PATH="./storage/strategy_state/execution_orders.json"
# Conservative supervised-paper starter caps. Live mode requires separately approved caps.
EXECUTION_MAX_ORDER_NOTIONAL="100"
EXECUTION_MAX_ORDER_SHARES="1"
EXECUTION_MAX_SYMBOL_POSITION_SHARES="1"
EXECUTION_MARKET_HOURS_GUARD="false"
EXECUTION_REQUIRE_PAPER_ACCOUNT="true"
LIVE_ENABLEMENT_3_SESSION_STABILITY_CONFIRMED="false"
LIVE_ENABLEMENT_LIVE_CREDENTIALS_VERIFIED="false"
LIVE_ENABLEMENT_RISK_CAPS_APPROVED="false"
ALPACA_API_KEY_ID="replace-with-alpaca-api-key-id"
ALPACA_API_SECRET_KEY="replace-with-alpaca-secret"
ALPACA_PAPER_BASE_URL="https://paper-api.alpaca.markets"
ALPACA_LIVE_BASE_URL="https://api.alpaca.markets"
ALPACA_ACCOUNT_ID="replace-with-alpaca-account-id"

# ==== Observability & Ops ====
PROMETHEUS_METRICS_PORT="9464"
GRAFANA_URL="http://localhost:3000"
GRAFANA_ADMIN_USER="replace-with-grafana-admin-user"
GRAFANA_ADMIN_PASSWORD="replace-with-strong-grafana-password"
ALERT_WEBHOOK_URL="https://hooks.example.com/alert"
RUNTIME_PROFILE="dev"
RUNTIME_BACKEND="in_memory"
# Local Docker recommendation: map host 55432 -> container 5432 to avoid host Postgres collisions.
POSTGRES_DSN="postgresql://postgres:postgres@localhost:55432/agenthedge"
RUNTIME_NAME="default"
RUNTIME_LEASE_SECONDS="30"
PORTFOLIO_ACCOUNT_ID="default"
PORTFOLIO_INITIAL_CASH="1000000"
BREAK_GLASS_ENABLED="false"
BREAK_GLASS_DEFAULT_TTL_SECONDS="900"
BREAK_GLASS_MAX_TTL_SECONDS="86400"
BUS_ACL_ENFORCE="false"
RUNTIME_BUS_DRAIN_TIMEOUT_SECONDS="2.0"
RUNTIME_AGENT_FAILURE_THRESHOLD="3"
RUNTIME_AGENT_FAILURE_ACTION="disable"
HEARTBEAT_MONITOR_ENABLED="true"
HEARTBEAT_TIMEOUT_SECONDS="300"
HEARTBEAT_KILL_SWITCH_ENABLED="false"
ANOMALY_DETECTION_ENABLED="true"
ANOMALY_WINDOW_SECONDS="60"
ANOMALY_BASELINE_WINDOWS="10"
ANOMALY_THRESHOLD_ZSCORE="2.5"
ANOMALY_CRITICAL_ZSCORE="4.0"
NETWORK_ALLOWLIST_ENABLED="true"
NETWORK_ALLOWLIST_ENFORCE="false"
NETWORK_ALLOWLIST_DOMAINS="finnhub.io,alphavantage.co,api.stlouisfed.org,newsapi.org"
RUNTIME_EVENT_LAG_ALERT_THRESHOLD="50"
RUNTIME_DELIVERY_RETRY_RATE_ALERT_THRESHOLD="0.01"
SCHEDULER_LEADERSHIP_CHURN_ALERT_THRESHOLD="2"
RUNTIME_FAILOVER_TIME_ALERT_THRESHOLD_SECONDS="10"

# ==== Experimental Research Strategies ====
# Empty by default. Set to "catalyst" only for local research/backtest experiments.
EXPERIMENTAL_STRATEGIES=""
# Required only when EXPERIMENTAL_STRATEGIES includes "catalyst".
CATALYST_RESEARCH_INPUT_PATH=""

# ==== Storage / Misc ====
DATA_CACHE_PATH="./.cache/data"
STRATEGY_STATE_PATH="./storage/strategy_state"
PORTFOLIO_STATE_PATH="./storage/strategy_state/portfolio.json"
AUDIT_LOG_PATH="./storage/audit"
LOG_LEVEL="INFO"
ENVIRONMENT="development"

# Copy this file to .env and fill real secrets locally.
